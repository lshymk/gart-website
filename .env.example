# G-ART 网站 - 环境变量配置文件
# 复制此文件为 .env.local 并填入实际值

# ========================================
# Vercel 部署配置
# ========================================
# 获取方式：访问 https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token-here

# ========================================
# 项目配置（自动生成，无需修改）
# ========================================
VERCEL_PROJECT_ID=qlgart-website
VERCEL_ORG_ID=lshymks-projects

# ========================================
# 其他配置
# ========================================
# 网站域名
NEXT_PUBLIC_SITE_URL=https://projects-self-one.vercel.app
